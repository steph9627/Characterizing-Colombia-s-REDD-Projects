  "acaba", "Pacific", "AUDD", 2014,
  "jaimacuru", "Amazon", "AUDD, ARR, IFM", 2019
)

# Classify projects as "AUDD alone" or "Other"
df <- df %>%
  mutate(Category = ifelse(Type == "AUDD", "AUDD only", "Mixed"))

# Count projects per Biome and Category
df_count <- df %>%
  group_by(Biome, Category) %>%
  summarise(n_projects = n(), .groups = 'drop')

# Calculate total projects per biome and percentages
df_count <- df_count %>%
  group_by(Biome) %>%
  mutate(
    total_biome = sum(n_projects),
    percent = n_projects / total_biome
  ) %>%
  ungroup()

# Define custom colors and font
custom_colors <- c("AUDD only" = "slategray4", "Mixed" = "cadetblue3")  # Change colors here
custom_font <- "Arial"  # Change font here
font_size <- 25  # Change font size here

# Save plot to JPG
jpeg(output_file, width = 14, height = 8, units = "in", res = 300)

# Create the bar chart
ggplot(df_count, aes(x = Biome, y = n_projects, fill = Category)) +
  geom_bar(stat = "identity", position = "stack", width=0.4) +
  geom_text(
    aes(
      label = paste0(round(percent * 100), "%"),
      group = Category
    ),
    position = position_stack(vjust = 0.5),
    color = "white",
    size = 8,
    fontface = "bold",
    family = custom_font
  ) +
  scale_fill_manual(values = custom_colors) +
  labs(
    title = " ",
    x = "Biome",
    y = "Number of Projects",
    fill = "Project Activites"
  ) +
  theme_minimal(base_family = custom_font) +
  theme(
    axis.text.x = element_text(angle = 0, hjust = 0.5, size = font_size),
    axis.text.y = element_text(size = font_size),
    axis.title = element_text(size = font_size + 2),
    legend.title = element_text(size = font_size, face="bold"),
    legend.text = element_text(size = font_size),
    plot.title = element_text(hjust= 0.5, size = font_size + 4, face = "bold"),
    panel.grid.major = element_line(color = "gray80")
  )

# Close the JPG device to save the file
dev.off()

# Confirmation message
cat("The bar chart has been saved to:", output_file, "\n")

