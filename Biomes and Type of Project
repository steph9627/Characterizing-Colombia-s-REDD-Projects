# Clear workspace
rm(list = ls())

# Load necessary libraries
library(dplyr)
library(ggplot2)
library(readr)
library(scales)

# Define folder path and output file
folder_path <- "INSERT YOUR FOLDER PATH HERE"
output_file <- file.path(folder_path, "projects_per_biome.jpg")

# Load the dataset
df <- tribble(
  ~Project, ~Biome, ~Type, ~Year, 
  "acapa", "Pacific", "AUDD", 2013,
  "arlequin", "Pacific", "AUDD, ARR, IFM", 2015, 
  "banakale", "Orinoco", "AUDD, ARR, IFM", 2016, 
  "banco2", "Andean", "AUDD, IFM", 2017, 
  "bcybm", "Pacific", "AUDD", 2013, 
  "cajambre", "Pacific", "AUDD", 2013, 
  "carmendarien", "Pacific", "AUDD", 2014, 
  "chocodarien", "Pacific", "AUDD, IFM", 2010,
  "cmari", "Amazon", "AUDD, ARR", 2017, 
  "co2biofasei", "Orinoco", "AUDD, ARR, IFM", 2015, 
  "co2biop2", "Orinoco", "AUDD", 2016, 
  "cocomacia", "Pacific", "IFM", 2016,
  "cocoman", "Pacific", "AUDD, ARR", 2016, 
  "concosta", "Pacific", "AUDD", 2013, 
  "corpochivor", "Andean", "AUDD, ARR", 2014, 
  "crimapredputu", "Amazon", "AUDD", 2018, 
  "dabucury", "Amazon", "AUDD", 2019,
  "delfines", "Pacific", "AUDD, ARR", 2010, 
  "tigre", "Orinoco", "AUDD", 2018, 
  "galilea", "Andean", "AUDD", 2010,
  "guacharos", "Andean", "AUDD", 2014,
  "kaliawiri", "Amazon", "AUDD, ARR", 2015,
  "magnolios", "Andean", "AUDD, ARR", 2016,
  "monocha", "Amazon", "AUDD", 2016,
  "mutata", "Andean", "AUDD", 2013,
  "naya", "Pacific", "AUDD, ARR",2016,
  "otun", "Andean", "AUDD, ARR", 2015, 
  "palameku", "Orinoco", "AUDD, ARR", 2010, 
  "parirgyrn", "Amazon", "AUDD", 2017, 
  "parivp1", "Amazon", "AUDD, ARR", 2018, 
  "Peliwaisi", "Amazon", "AUDD, ARR", 2015, 
  "prediopu", "Amazon", "AUDD", 2016,
  "siviru", "Pacific", "AUDD", 2013, 
  "tangara", "Pacific", "AUDD", 2010, 
  "yaawii", "Amazon", "AUDD, ARR, IFM", 2015, 
  "yutucu", "Amazon", "AUDD", 2016,
  "zabalo", "Amazon", "AUDD, ARR", 2018,
  "cispata", "Caribbean", "AUDD", 2015,
  "bosquespaz", "Amazon", "AUDD", 2019, 
